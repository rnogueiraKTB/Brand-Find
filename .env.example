SECRET_KEY=replace-with-a-strong-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,brands.your-domain.com
CSRF_TRUSTED_ORIGINS=https://brands.your-domain.com
POSTGRES_DB=brandfind
POSTGRES_USER=brandfind
POSTGRES_PASSWORD=replace-with-a-strong-password
USE_SQLITE=False
DATABASE_URL=postgresql://brandfind:replace-with-a-strong-password@db:5432/brandfind

# HTTPS hardening (optional)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
